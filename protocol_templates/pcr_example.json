{
  "protocol_name": "Colony PCR",
  "version": "1.0",
  "author": "",
  "storage_items": [
    {
      "key": "pcr_product",
      "label": "PCR 产物",
      "tube_type": "1.5mL EP管",
      "default_box": "",
      "notes_template": "Colony #{n}"
    }
  ],
  "steps": [
    {
      "title": "配制 PCR 反应体系",
      "description": "取 12.5µL 2× Taq Mix，加入 1µL 模板（菌落挑取），正向引物 1µL，反向引物 1µL，补 ddH₂O 至 25µL。",
      "timer_seconds": 0,
      "has_camera": false,
      "camera_required": false,
      "fields": [
        {
          "key": "colony_count",
          "label": "菌落数量",
          "type": "number",
          "default": "8",
          "required": true,
          "options": []
        },
        {
          "key": "primer_name",
          "label": "引物名称",
          "type": "text",
          "default": "",
          "required": false,
          "options": []
        }
      ]
    },
    {
      "title": "PCR 扩增",
      "description": "PCR 程序：94°C 预变性 3min → (94°C 30s → 55°C 30s → 72°C 90s) × 30 循环 → 72°C 延伸 5min → 4°C 保存。",
      "timer_seconds": 3600,
      "has_camera": false,
      "camera_required": false,
      "fields": [
        {
          "key": "annealing_temp",
          "label": "退火温度 (°C)",
          "type": "number",
          "default": "55",
          "required": false,
          "options": []
        },
        {
          "key": "extension_time",
          "label": "延伸时间 (s)",
          "type": "number",
          "default": "90",
          "required": false,
          "options": []
        }
      ]
    },
    {
      "title": "琼脂糖凝胶电泳",
      "description": "配制 1% 琼脂糖凝胶，取 5µL PCR 产物 + 1µL 6× Loading Buffer，100V 电泳 30min。",
      "timer_seconds": 1800,
      "has_camera": true,
      "camera_required": true,
      "fields": [
        {
          "key": "gel_percent",
          "label": "凝胶浓度 (%)",
          "type": "number",
          "default": "1",
          "required": false,
          "options": []
        },
        {
          "key": "voltage",
          "label": "电压 (V)",
          "type": "number",
          "default": "100",
          "required": false,
          "options": []
        }
      ]
    },
    {
      "title": "结果判读",
      "description": "在紫外灯下观察凝胶，记录阳性克隆编号（出现目的条带）。预期条带大小：约 800bp。",
      "timer_seconds": 0,
      "has_camera": true,
      "camera_required": false,
      "fields": [
        {
          "key": "positive_colonies",
          "label": "阳性克隆编号",
          "type": "text",
          "default": "",
          "required": false,
          "options": []
        },
        {
          "key": "band_size",
          "label": "条带大小 (bp)",
          "type": "number",
          "default": "800",
          "required": false,
          "options": []
        }
      ]
    }
  ]
}
